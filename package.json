{
  "name": "shift-ops",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "GOCACHE=$(pwd)/.cache/go-build sh -c 'cd services/api && go run .'",
    "dev:studio": "pnpm --filter studio dev",
    "podman:up": "sh ./scripts/podman-up.sh",
    "podman:down": "sh ./scripts/podman-down.sh",
    "lint:web": "pnpm --filter web lint",
    "typecheck:web": "pnpm --filter web typecheck",
    "build:web": "pnpm --filter web build",
    "build:studio": "pnpm --filter studio build",
    "build:api": "GOCACHE=$(pwd)/.cache/go-build sh -c 'cd services/api && go build ./...'",
    "test:api": "GOCACHE=$(pwd)/.cache/go-build sh -c 'cd services/api && go test ./...'",
    "test:e2e": "playwright test",
    "check": "sh ./scripts/check.sh",
    "build": "pnpm build:web && pnpm build:studio && pnpm build:api",
    "version:sync": "node scripts/version.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
